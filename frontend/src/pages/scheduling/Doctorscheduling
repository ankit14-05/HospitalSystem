export default function DoctorScheduling() {
  const { user } = useAuth();

  // State
  const [schedules,     setSchedules]     = useState([]);
  const [leaves,        setLeaves]        = useState([]);
  const [appointments,  setAppointments]  = useState([]);
  const [doctorProfile, setDoctorProfile] = useState(null);

  const [loadingSched, setLoadingSched] = useState(true);
  const [loadingLeave, setLoadingLeave] = useState(true);
  const [loadingAppts, setLoadingAppts] = useState(true);

  const [activeTab, setActiveTab]   = useState('today');
  const [modal,     setModal]       = useState(null); // 'add' | 'edit' | 'leave'
  const [editing,   setEditing]     = useState(null);
  const [saving,    setSaving]      = useState(false);
  const [defaultDay, setDefaultDay] = useState(TODAY_DOW);

  // ── Fetch doctor profile ──────────────────────────────────────────────────
  const fetchProfile = useCallback(async () => {
    try {
      const r = await api.get('/doctors/profile');
      const d = r?.data?.data ?? r?.data ?? r;
      setDoctorProfile(d);
    } catch {}
  }, []);

  // ── Fetch schedules ───────────────────────────────────────────────────────
  const fetchSchedules = useCallback(async () => {
    setLoadingSched(true);
    try {
      const r = await api.get('/doctors/my-schedule');
      const list = r?.data?.data ?? r?.data ?? r ?? [];
      setSchedules(Array.isArray(list) ? list : []);
    } catch {
      // Fallback: try the OPD schedule endpoint
      try {
        const r2 = await api.get('/doctors/schedule');
        const list2 = r2?.data?.data ?? r2?.data ?? r2 ?? [];
        // Convert OPD schedule rows to block format
        const converted = (Array.isArray(list2) ? list2 : []).map(s => ({
          ...s,
          BlockType: 'opd',
          Title: 'OPD Clinic',
        }));
        setSchedules(converted);
      } catch {
        setSchedules([]);
      }
    }
    setLoadingSched(false);
  }, []);

  // ── Fetch leaves ──────────────────────────────────────────────────────────
  const fetchLeaves = useCallback(async () => {
    setLoadingLeave(true);
    try {
      const r = await api.get('/doctors/my-leaves');
      const list = r?.data?.data ?? r?.data ?? r ?? [];
      setLeaves(Array.isArray(list) ? list : []);
    } catch {
      try {
        // Fallback to scheduling endpoint
        const r2 = await api.get('/scheduling/doctor-leaves?status=');
        const list2 = r2?.data?.data ?? r2?.data ?? r2 ?? [];
        setLeaves(Array.isArray(list2) ? list2 : []);
      } catch { setLeaves([]); }
    }
    setLoadingLeave(false);
  }, []);

  // ── Fetch appointments ────────────────────────────────────────────────────
  const fetchAppointments = useCallback(async () => {
    setLoadingAppts(true);
    try {
      const r = await api.get('/appointments/pending-requests');
      const list = r?.data?.data ?? r?.data ?? r ?? [];
      // Also get today's queue
      const r2 = await api.get(`/appointments/my-queue?date=${TODAY_STR}`);
      const queue = r2?.data?.data ?? r2?.data ?? r2 ?? [];
      // Merge: queue items get AppointmentDate injected
      const queueAppts = (Array.isArray(queue)?queue:[]).map(q => ({
        ...q,
        AppointmentDate: q.AppointmentDate || TODAY_STR,
        AppointmentTime: q.AppointmentTime || q.StartTime,
        PatientName: q.PatientFullName || q.PatientName,
        Status: q.QueueStatus || q.Status || 'scheduled',
      }));
      const combined = [...(Array.isArray(list)?list:[]), ...queueAppts];
      // Deduplicate by Id
      const seen = new Set();
      setAppointments(combined.filter(a => {
        if (seen.has(a.Id)) return false;
        seen.add(a.Id);
        return true;
      }));
    } catch { setAppointments([]); }
    setLoadingAppts(false);
  }, []);

  useEffect(() => {
    fetchProfile();
    fetchSchedules();
    fetchLeaves();
    fetchAppointments();
  }, []);

  // ── Save schedule block ───────────────────────────────────────────────────
  const handleSaveSchedule = async (form) => {
    if (!form.StartTime || !form.EndTime) {
      toast.error('Start time and end time are required'); return;
    }
    setSaving(true);
    try {
      const payload = {
        BlockType:       form.BlockType,
        DayOfWeek:       Number(form.DayOfWeek),
        StartTime:       form.StartTime,
        EndTime:         form.EndTime,
        Title:           form.Title || null,
        Location:        form.Location || null,
        Notes:           form.Notes || null,
        SlotDurationMins: form.BlockType === 'opd' ? Number(form.SlotDurationMins) || 15 : null,
        MaxPatients:     form.MaxPatients ? Number(form.MaxPatients) : null,
        PatientCount:    form.PatientCount ? Number(form.PatientCount) : null,
        Recurrence:      form.Recurrence || 'weekly',
        EffectiveFrom:   form.EffectiveFrom,
        EffectiveTo:     form.EffectiveTo || null,
      };

      if (editing) {
        await api.put(`/doctors/my-schedule/${editing.Id}`, payload);
        toast.success('Schedule block updated');
      } else {
        await api.post('/doctors/my-schedule', payload);
        toast.success('Schedule block added');
      }
      setModal(null);
      setEditing(null);
      fetchSchedules();
    } catch (e) {
      toast.error(e.response?.data?.message || 'Failed to save schedule');
    }
    setSaving(false);
  };

  // ── Delete schedule block ─────────────────────────────────────────────────
  const handleDelete = async (id) => {
    if (!window.confirm('Remove this schedule block?')) return;
    try {
      await api.delete(`/doctors/my-schedule/${id}`);
      toast.success('Block removed');
      fetchSchedules();
    } catch (e) {
      toast.error(e.response?.data?.message || 'Delete failed');
    }
  };

  // ── Save leave ────────────────────────────────────────────────────────────
  const handleSaveLeave = async (form) => {
    if (!form.Reason?.trim()) { toast.error('Reason is required'); return; }
    setSaving(true);
    try {
      await api.post('/doctors/my-leaves', {
        LeaveDate:   form.LeaveDate,
        EndDate:     form.EndDate || form.LeaveDate,
        LeaveType:   form.LeaveType,
        StartTime:   form.StartTime || null,
        EndTime:     form.EndTime   || null,
        Reason:      form.Reason,
        IsEmergency: form.IsEmergency || false,
      });
      toast.success('Leave request submitted');
      setModal(null);
      fetchLeaves();
    } catch (e) {
      toast.error(e.response?.data?.message || 'Failed to submit leave');
    }
    setSaving(false);
  };

  // ── Open add / edit ───────────────────────────────────────────────────────
  const openAdd = (dayIndex = TODAY_DOW) => {
    setDefaultDay(dayIndex);
    setEditing(null);
    setModal('add');
  };

  const openEdit = (block) => {
    setEditing(block);
    setModal('edit');
  };

  // ── Tabs ──────────────────────────────────────────────────────────────────
  const TABS = [
    { key: 'today',        label: "Today's Schedule",  icon: Clock     },
    { key: 'weekly',       label: 'Weekly View',       icon: Calendar  },
    { key: 'appointments', label: 'Appointments',      icon: User      },
    { key: 'leaves',       label: 'Leave Requests',    icon: CalendarOff },
  ];

  const p = doctorProfile || {};

  return (
    <div className="space-y-5">

      {/* ── Header ── */}
      <div className="flex items-center justify-between flex-wrap gap-3">
        <div>
          <h1 className="text-xl font-bold text-slate-900 flex items-center gap-2">
            <Calendar size={20} className="text-teal-500" />
            My Schedule
          </h1>
          <p className="text-sm text-slate-400 mt-0.5">
            {p.Specialization || 'Doctor'} · {p.DepartmentName || ''}
            {p.AvailableFrom && p.AvailableTo && (
              <span className="ml-2 text-teal-600 font-medium">
                OPD: {fmt12(p.AvailableFrom)} – {fmt12(p.AvailableTo)}
              </span>
            )}
          </p>
        </div>
        <div className="flex items-center gap-2">
          <button onClick={() => { fetchSchedules(); fetchLeaves(); fetchAppointments(); }}
            className="flex items-center gap-1.5 px-3 py-2 rounded-xl border border-slate-200 text-sm text-slate-600 hover:bg-slate-50 transition-colors">
            <RefreshCw size={13} /> Refresh
          </button>
          <button onClick={() => openAdd(TODAY_DOW)}
            className="flex items-center gap-1.5 px-4 py-2 rounded-xl bg-teal-600 text-white text-sm font-semibold hover:bg-teal-700 transition-colors">
            <Plus size={14} /> Add Block
          </button>
          <button onClick={() => setModal('leave')}
            className="flex items-center gap-1.5 px-4 py-2 rounded-xl bg-amber-500 text-white text-sm font-semibold hover:bg-amber-600 transition-colors">
            <CalendarOff size={14} /> Request Leave
          </button>
        </div>
      </div>

      {/* ── Summary chips ── */}
      <div className="flex flex-wrap gap-3">
        {Object.entries(BLOCK_TYPES).map(([k, c]) => {
          const count = schedules.filter(s => s.BlockType === k && s.IsActive !== false).length;
          if (!count) return null;
          const Icon = c.icon;
          return (
            <div key={k} className={`flex items-center gap-2 px-3 py-2 rounded-xl border text-xs font-semibold ${c.color}`}>
              <Icon size={12} />
              <span>{count} {c.label}</span>
            </div>
          );
        })}
        {leaves.filter(l => l.Status === 'pending').length > 0 && (
          <div className="flex items-center gap-2 px-3 py-2 rounded-xl border bg-amber-50 border-amber-200 text-amber-700 text-xs font-semibold">
            <AlertCircle size={12} />
            {leaves.filter(l => l.Status === 'pending').length} leave request{leaves.filter(l=>l.Status==='pending').length>1?'s':''} pending
          </div>
        )}
      </div>

      {/* ── Tab bar ── */}
      <div className="flex gap-0 border-b border-slate-200 overflow-x-auto">
        {TABS.map(({ key, label, icon: Icon }) => (
          <button key={key} onClick={() => setActiveTab(key)}
            className={`flex items-center gap-2 px-5 py-3 text-sm font-semibold border-b-2 whitespace-nowrap transition-all
              ${activeTab === key
                ? 'border-teal-600 text-teal-700'
                : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'}`}>
            <Icon size={14} /> {label}
          </button>
        ))}
      </div>

      {/* ── Tab content ── */}
      {activeTab === 'today' && (
        <TodayTab
          schedules={schedules}
          appointments={appointments}
          loading={loadingSched}
          onEdit={openEdit}
          onDelete={handleDelete}
        />
      )}
      {activeTab === 'weekly' && (
        <WeeklyTab
          schedules={schedules}
          loading={loadingSched}
          onAdd={openAdd}
          onEdit={openEdit}
          onDelete={handleDelete}
        />
      )}
      {activeTab === 'appointments' && (
        <AppointmentsTab
          appointments={appointments}
          loading={loadingAppts}
          onRefresh={fetchAppointments}
        />
      )}
      {activeTab === 'leaves' && (
        <LeaveTab
          leaves={leaves}
          loading={loadingLeave}
          onNew={() => setModal('leave')}
          onRefresh={fetchLeaves}
        />
      )}

      {/* ── Modals ── */}
      <Modal
        open={modal === 'add' || modal === 'edit'}
        onClose={() => { setModal(null); setEditing(null); }}
        title={modal === 'edit' ? 'Edit Schedule Block' : 'Add Schedule Block'}
        width="max-w-xl">
        <ScheduleForm
          initial={modal === 'edit' && editing ? {
            BlockType:       editing.BlockType || 'opd',
            DayOfWeek:       String(editing.DayOfWeek ?? TODAY_DOW),
            StartTime:       (editing.StartTime||'').slice(0,5),
            EndTime:         (editing.EndTime||'').slice(0,5),
            Title:           editing.Title || '',
            Location:        editing.Location || '',
            Notes:           editing.Notes || '',
            SlotDurationMins: String(editing.SlotDurationMins || 15),
            PatientCount:    String(editing.PatientCount || ''),
            MaxPatients:     String(editing.MaxPatients || ''),
            Recurrence:      editing.Recurrence || 'weekly',
            EffectiveFrom:   (editing.EffectiveFrom||TODAY_STR).slice(0,10),
            EffectiveTo:     (editing.EffectiveTo||'').slice(0,10),
          } : { ...blank(), DayOfWeek: String(defaultDay) }}
          onSave={handleSaveSchedule}
          onCancel={() => { setModal(null); setEditing(null); }}
          saving={saving}
        />
      </Modal>

      <Modal
        open={modal === 'leave'}
        onClose={() => setModal(null)}
        title="Request Leave"
        width="max-w-md">
        <LeaveForm
          onSave={handleSaveLeave}
          onCancel={() => setModal(null)}
          saving={saving}
        />
      </Modal>
    </div>
  );
}