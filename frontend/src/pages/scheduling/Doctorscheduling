      <div className="grid grid-cols-2 gap-3">
        <Field label="Day of Week" required>
          <Select value={form.DayOfWeek} onChange={e => f('DayOfWeek', e.target.value)}>
            {DAYS_FULL.map((d, i) => <option key={i} value={i}>{d}</option>)}
          </Select>
        </Field>
        <Field label="Title / Label">
          <Input value={form.Title} onChange={e => f('Title', e.target.value)}
            placeholder={cfg.label} />
        </Field>
      </div>

      {/* Time */}
      <div className="grid grid-cols-2 gap-3">
        <Field label="Start Time" required>
          <Input type="time" value={form.StartTime} onChange={e => f('StartTime', e.target.value)} />
        </Field>
        <Field label="End Time" required>
          <Input type="time" value={form.EndTime} onChange={e => f('EndTime', e.target.value)} />
        </Field>
      </div>

      {/* Duration preview */}
      {durMins > 0 && (
        <div className={`px-3 py-2 rounded-lg border text-xs font-medium ${cfg.color}`}>
          Duration: <strong>{durMins} min</strong> ({fmt12(form.StartTime)} – {fmt12(form.EndTime)})
