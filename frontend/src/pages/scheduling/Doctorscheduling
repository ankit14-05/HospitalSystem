// ─────────────────────────────────────────────────────────────────────────────
// Tab: Today's Schedule
// ─────────────────────────────────────────────────────────────────────────────
const TodayTab = ({ schedules, appointments, loading, onEdit, onDelete }) => {
  // Get today's blocks
  const todayBlocks = schedules.filter(s => s.DayOfWeek === TODAY_DOW && s.IsActive !== false);
  const sorted = [...todayBlocks].sort((a, b) => toMinutes(a.StartTime) - toMinutes(b.StartTime));

  // Today's appointments
  const todayAppts = appointments.filter(a => {
    const d = (a.AppointmentDate || '').slice(0, 10);
    return d === TODAY_STR;
  }).sort((a, b) => toMinutes(a.AppointmentTime) - toMinutes(b.AppointmentTime));

  const now = new Date();
  const nowMins = now.getHours() * 60 + now.getMinutes();

  const getCurrentBlock = () =>
    sorted.find(b => toMinutes(b.StartTime) <= nowMins && toMinutes(b.EndTime) > nowMins);
  const getNextBlock = () =>
    sorted.find(b => toMinutes(b.StartTime) > nowMins);

  const currentBlock = getCurrentBlock();
  const nextBlock    = getNextBlock();

  if (loading) {
    return (
      <div className="space-y-3">
        {[1,2,3].map(i => (
          <div key={i} className="h-24 bg-slate-100 rounded-2xl animate-pulse" />
        ))}
      </div>
    );
  }

  return (
    <div className="space-y-5">
      {/* Status strip */}
      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <Card className="p-4">
          <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-1.5">
            <span className="w-2 h-2 rounded-full bg-green-500 animate-pulse" /> Now
          </p>
          {currentBlock ? (
            <div>
              <div className="flex items-center gap-2 mb-1">
                {(() => { const Icon = (BLOCK_TYPES[currentBlock.BlockType]||BLOCK_TYPES.opd).icon; return <Icon size={16} style={{ color:(BLOCK_TYPES[currentBlock.BlockType]||BLOCK_TYPES.opd).accent }}/>; })()}
                <p className="font-bold text-slate-800 text-sm">{currentBlock.Title || (BLOCK_TYPES[currentBlock.BlockType]||BLOCK_TYPES.opd).label}</p>
              </div>
              <p className="text-xs text-slate-500">{fmt12(currentBlock.StartTime)} – {fmt12(currentBlock.EndTime)}</p>
              {currentBlock.Location && <p className="text-xs text-slate-400 mt-0.5 flex items-center gap-1"><MapPin size={10}/>{currentBlock.Location}</p>}
            </div>
          ) : (
            <p className="text-sm text-slate-400">No scheduled activity right now</p>
          )}
        </Card>

        <Card className="p-4">
          <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-1.5">
            <Bell size={10} /> Up Next
          </p>
          {nextBlock ? (
            <div>
              <div className="flex items-center gap-2 mb-1">
                {(() => { const Icon = (BLOCK_TYPES[nextBlock.BlockType]||BLOCK_TYPES.opd).icon; return <Icon size={16} style={{ color:(BLOCK_TYPES[nextBlock.BlockType]||BLOCK_TYPES.opd).accent }}/>; })()}
                <p className="font-bold text-slate-800 text-sm">{nextBlock.Title || (BLOCK_TYPES[nextBlock.BlockType]||BLOCK_TYPES.opd).label}</p>
              </div>
              <p className="text-xs text-slate-500">Starts at {fmt12(nextBlock.StartTime)}</p>
              <p className="text-xs text-teal-600 font-semibold mt-0.5">
                in {toMinutes(nextBlock.StartTime) - nowMins} min
              </p>
            </div>
          ) : (
            <p className="text-sm text-slate-400">No more scheduled activities today</p>
          )}
        </Card>
      </div>

      {/* Timeline */}
      <Card>
        <div className="px-5 py-3 border-b border-slate-100 flex items-center justify-between">
          <h3 className="font-bold text-slate-700 flex items-center gap-2">
            <Calendar size={15} className="text-teal-500" />
            Today's Schedule — {new Date().toLocaleDateString('en-IN', { weekday:'long', day:'2-digit', month:'long' })}
          </h3>
          <Badge color="bg-teal-100 text-teal-700">{sorted.length} blocks</Badge>
        </div>
        <div className="p-5">
          {sorted.length === 0 ? (
            <Empty icon={Calendar} text="No schedule for today" sub="Add blocks using the Weekly Schedule tab" />
          ) : (
            <div className="space-y-3">
              {sorted.map(b => (
                <div key={b.Id} className={b === currentBlock ? 'ring-2 ring-teal-400 ring-offset-2 rounded-2xl' : ''}>
                  <TimelineBlock block={b} onEdit={onEdit} onDelete={onDelete} />
                </div>
              ))}
            </div>
          )}
        </div>
      </Card>

      {/* Today's Appointments */}
      {todayAppts.length > 0 && (
        <Card>
          <div className="px-5 py-3 border-b border-slate-100 flex items-center justify-between">
            <h3 className="font-bold text-slate-700 flex items-center gap-2">
              <User size={15} className="text-blue-500" /> Today's Appointments
            </h3>
            <Badge color="bg-blue-100 text-blue-700">{todayAppts.length}</Badge>
          </div>
          <div className="divide-y divide-slate-50">
            {todayAppts.map(a => {
              const status = (a.Status||'').toLowerCase();
              const statusColor = {
                scheduled: 'bg-amber-100 text-amber-700',
                confirmed: 'bg-blue-100 text-blue-700',
                completed: 'bg-green-100 text-green-700',
                cancelled: 'bg-slate-100 text-slate-400',
                noshow:    'bg-red-100 text-red-600',
              }[status] || 'bg-slate-100 text-slate-500';

              return (
                <div key={a.Id} className="flex items-center gap-4 px-5 py-3 hover:bg-slate-50 transition-colors">
                  <div className="w-14 text-center flex-shrink-0">
                    <p className="text-sm font-bold text-slate-700">{fmt12(a.AppointmentTime)}</p>
                    <p className="text-[10px] text-slate-400">#{a.TokenNumber}</p>
                  </div>
                  <div className="flex-1 min-w-0">
                    <p className="font-semibold text-slate-800 text-sm">{a.PatientName || 'Patient'}</p>
                    <p className="text-xs text-slate-400">{a.VisitType} {a.Reason ? `· ${a.Reason}` : ''}</p>
                  </div>
                  <Badge color={statusColor} className="capitalize">{a.Status}</Badge>
                </div>
              );
            })}
          </div>
        </Card>
      )}
    </div>
  );
};

