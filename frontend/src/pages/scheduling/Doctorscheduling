          )}
        </div>
        {block.Notes && <p className="text-xs text-slate-400 mt-1.5 italic">{block.Notes}</p>}
      </div>
      <div className="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0">
