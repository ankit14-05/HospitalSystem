  const end   = fmt12(block.EndTime);
  const dur   = toMinutes(block.EndTime) - toMinutes(block.StartTime);

  return (
    <div className={`group relative flex items-start gap-3 p-4 rounded-2xl border-l-4 border ${cfg.color} transition-all hover:shadow-md`}
      style={{ borderLeftColor: cfg.accent }}>
      <div className="flex flex-col items-center gap-1 flex-shrink-0 w-16">
        <span className="text-xs font-bold text-slate-700">{start}</span>
        <div className={`w-0.5 flex-1 min-h-[16px] ${cfg.dot} opacity-30 rounded-full`} />
        <span className="text-xs text-slate-400">{end}</span>
      </div>
      <div className="flex-1 min-w-0">
        <div className="flex items-center gap-2 flex-wrap">
          <div className={`w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0`}
            style={{ background: `${cfg.accent}15` }}>
            <Icon size={14} style={{ color: cfg.accent }} />
          </div>
          <p className="font-bold text-slate-800 text-sm">{cfg.label}</p>
          <Badge color={cfg.badge}>{dur} min</Badge>
          {block.IsRecurring && <Badge color="bg-slate-100 text-slate-500"><Repeat size={9} className="mr-1" />Recurring</Badge>}
        </div>
        {block.Title && <p className="text-sm text-slate-600 mt-1 font-medium">{block.Title}</p>}
        <div className="flex flex-wrap gap-x-4 gap-y-1 mt-1.5">
          {block.Location && (
            <span className="flex items-center gap-1 text-xs text-slate-400">
              <MapPin size={10} /> {block.Location}
            </span>
          )}
          {block.PatientCount > 0 && (
            <span className="flex items-center gap-1 text-xs text-slate-400">
              <User size={10} /> {block.PatientCount} patients
            </span>
          )}
          {block.SlotDurationMins && block.BlockType === 'opd' && (
            <span className="flex items-center gap-1 text-xs text-slate-400">
              <Hash size={10} /> {Math.floor(dur / block.SlotDurationMins)} slots · {block.SlotDurationMins} min each
