        {onDelete && (
          <button onClick={() => onDelete(block.Id)}
            className="p-1.5 rounded-lg hover:bg-red-50 text-red-400 transition-colors"><Trash2 size={12}/></button>
        )}
      </div>
    </div>
  );
};

